# ═══════════════════════════════════════════════════════════════
#  Salesforce MCP — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=9856
ENVIRONMENT=development

# ─── Salesforce OAuth (Connected App) ─────────────────────────
# Use https://login.salesforce.com for production / Developer Edition
# Use https://test.salesforce.com for Sandbox orgs
SF_LOGIN_URL=https://login.salesforce.com

# From your Connected App: Setup → App Manager → Your App → View
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here

# Must exactly match the Callback URL set in the Connected App
SF_REDIRECT_URI=http://localhost:9856/api/auth/callback

# ─── Token Storage ─────────────────────────────────────────────
# Where per-user OAuth tokens are stored as {user_id}.json files
SF_TOKENS_DIR=./tokens

# ─── Anthropic (NLP query endpoint) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
